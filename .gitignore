# ============================================================
# FUVIA X — .gitignore
# Backend (FastAPI) + Agent (LangGraph) + Frontend (React/Vite)
# ============================================================

# ----------------------------------------------------------------
# SEGURIDAD — nunca subir al repo
# ----------------------------------------------------------------
.env
.env.local
.env.*.local
*.key
*.pem
secrets/

# ----------------------------------------------------------------
# PYTHON — entornos virtuales y caché
# ----------------------------------------------------------------
venv/
.venv/
env/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/

# ----------------------------------------------------------------
# MODELOS ML — archivos grandes, no van en git
# Gestionar con Git LFS o descargar en deploy
# ----------------------------------------------------------------
*.joblib
*.pkl
*.h5
*.pt
*.pth
models/

# ----------------------------------------------------------------
# BASE DE DATOS VECTORIAL — se re-genera con ingest.py
# ----------------------------------------------------------------
agent/rag/chroma_db/

# ----------------------------------------------------------------
# DATOS NORMATIVOS — PDFs originales (copyright)
# Solo subir data_clean/ (texto preprocesado sin copyright)
# ----------------------------------------------------------------
agent/rag/data/

# ----------------------------------------------------------------
# REPORTES DE AUDITORÍA — se re-generan con audit_tables.py
# ----------------------------------------------------------------
agent/rag/audit_report/

# ----------------------------------------------------------------
# BASE DE DATOS LOCAL (SQLite)
# ----------------------------------------------------------------
*.db
*.sqlite
*.sqlite3

# ----------------------------------------------------------------
# FRONTEND — dependencias y build
# ----------------------------------------------------------------
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/

# ----------------------------------------------------------------
# LOGS
# ----------------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ----------------------------------------------------------------
# EDITORES E IDEs
# ----------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ----------------------------------------------------------------
# TESTING
# ----------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# ----------------------------------------------------------------
# RENDER — archivos de deploy local
# ----------------------------------------------------------------
.render/